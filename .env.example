# Public (exposed to the browser — must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# The website name and logo are NOT configured here — they live in Website
# Settings (Admin → Settings → Branding) and are stored in Supabase.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only secrets go below (never prefix with NEXT_PUBLIC_)
# Examples for later phases — leave empty until those features are built:
# DATABASE_URL=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# AUTH_SECRET=
